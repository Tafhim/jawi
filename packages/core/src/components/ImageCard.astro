---
export interface Props {
  image: string;
  alt?: string;
  large?: boolean;
  variant?: 'full' | 'compact';
}

const { image, alt = 'Image', large = false, variant = 'full' } = Astro.props;
const isLarge = large === true;
const cardStyles = {
  full: {
    width: '100%',
    height: 'auto',
    aspectRatio: 'auto'
  },
  compact: {
    width: '100%',
    height: '200px',
    objectFit: 'cover'
  }
};
---

<style>
  .image-card {
    background-color: #1a1a1a;
    border-radius: 12px;
    overflow: hidden;
    margin-bottom: 1.5rem;
    border: 1px solid #333333;
    box-shadow: 0 4px 8px rgba(0, 0, 0, 0.3), 0 2px 4px rgba(0, 0, 0, 0.2);
    transition: box-shadow 0.2s ease;
  }

  .image-card:hover {
    box-shadow: 0 6px 12px rgba(0, 0, 0, 0.4), 0 3px 6px rgba(0, 0, 0, 0.25);
  }

  .image-card--large {
    border-radius: 16px;
    margin-bottom: 2rem;
    box-shadow: 0 6px 12px rgba(0, 0, 0, 0.4), 0 3px 8px rgba(0, 0, 0, 0.25);
  }

  .image-card--compact {
    margin-bottom: 1rem;
    border-radius: 8px;
  }

  .image-card img {
    display: block;
    width: 100%;
    height: auto;
    transition: transform 0.3s ease;
  }

  .image-card:hover img {
    transform: scale(1.01);
  }

  @media (max-width: 768px) {
    .image-card {
      margin-bottom: 1rem;
      border-radius: 12px;
      box-shadow: 0 2px 6px rgba(0, 0, 0, 0.3);
    }

    .image-card--large {
      margin-bottom: 1.25rem;
      border-radius: 12px;
      box-shadow: 0 3px 8px rgba(0, 0, 0, 0.35);
    }

    .image-card img {
      max-height: 300px;
    }
  }

  @media (max-width: 480px) {
    .image-card {
      margin-bottom: 0.75rem;
      border-radius: 10px;
      box-shadow: 0 1px 4px rgba(0, 0, 0, 0.25);
    }

    .image-card img {
      max-height: 200px;
    }
  }
</style>

<div class={`image-card ${isLarge ? 'image-card--large' : ''} ${variant ? 'image-card--' + variant : ''}`}>
  <img 
    src={image.replace(/^\/static\/images\//, '/public/').replace(/^https?:\/\//, '')} 
    alt={alt} 
    loading={isLarge ? 'eager' : 'lazy'}
    style={cardStyles[variant]}
    onerror={(e) => {
      const target = e.target;
      const card = target.closest('.image-card');
      if (card) {
        card.style.display = 'none';
      }
    }}
  />
</div>
