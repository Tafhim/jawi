---
interface Props {
  siteTitle?: string;
}

const { siteTitle = 'Jawi' } = Astro.props;
---

<div class="header-wrapper">
  <div class="header-row">
    <a href="/" class="logo">
      <span class="glitch-triple">{siteTitle}</span>
    </a>
    <nav class="nav-desktop">
      <a href="/" class="nav-link">Home</a>
      <a href="/codes" class="nav-link">Codes</a>
      <a href="/thoughts" class="nav-link">Thoughts</a>
      <a href="/tags" class="nav-link">Tags</a>
      <a href="/posts" class="nav-link">Posts</a>
    </nav>
    <button class="hamburger-btn" aria-label="Open menu" id="hamburger-btn">
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
    </button>
  </div>
</div>

<div class="mobile-overlay" id="mobile-overlay">
  <button class="close-btn" aria-label="Close menu" id="close-btn">&times;</button>
  <nav class="mobile-nav">
    <a href="/" class="mobile-nav-link">Home</a>
    <a href="/codes" class="mobile-nav-link">Codes</a>
    <a href="/thoughts" class="mobile-nav-link">Thoughts</a>
    <a href="/tags" class="mobile-nav-link">Tags</a>
    <a href="/posts" class="mobile-nav-link">Posts</a>
  </nav>
</div>

<script>
  const hamburger = document.getElementById('hamburger-btn');
  const overlay = document.getElementById('mobile-overlay');
  const closeBtn = document.getElementById('close-btn');
  const mobileLinks = document.querySelectorAll('.mobile-nav-link');

  function openMenu() {
    overlay.classList.add('open');
    document.body.classList.add('no-scroll');
  }

  function closeMenu() {
    overlay.classList.remove('open');
    document.body.classList.remove('no-scroll');
  }

  hamburger.addEventListener('click', openMenu);
  closeBtn.addEventListener('click', closeMenu);

  mobileLinks.forEach(link => {
    link.addEventListener('click', closeMenu);
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && overlay.classList.contains('open')) {
      closeMenu();
    }
  });
</script>

<style>
  .header-wrapper {
    padding: 1rem 0;
    margin-bottom: 1rem;
  }

  .header-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }

  .logo {
    color: var(--text-primary);
    font-size: 1.1rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    flex-shrink: 0;
  }

  .logo:hover {
    opacity: 1;
  }

  .nav-desktop {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .nav-link {
    color: var(--text-muted, #ccc);
    font-size: 0.95rem;
    font-weight: 400;
    transition: color 0.2s ease;
  }

  .nav-link:hover {
    color: var(--text-primary);
    opacity: 1;
  }

  /* Hamburger button - hidden on desktop */
  .hamburger-btn {
    display: none;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    width: 2.5rem;
    height: 2.5rem;
    background: transparent;
    border: 1px solid var(--border-color, #333);
    cursor: pointer;
    gap: 0.35rem;
    padding: 0.4rem;
  }

  .hamburger-btn:hover {
    border-color: var(--text-primary, #fff);
  }

  .hamburger-line {
    display: block;
    width: 100%;
    height: 2px;
    background-color: var(--text-primary, #fff);
  }

  /* Mobile overlay */
  .mobile-overlay {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.95);
    z-index: 1000;
    opacity: 0;
    transition: opacity 0.2s ease;
  }

  .mobile-overlay.open {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    opacity: 1;
  }

  .close-btn {
    position: absolute;
    top: 1.5rem;
    right: 1.5rem;
    background: transparent;
    border: none;
    color: var(--text-primary, #fff);
    font-size: 2.5rem;
    cursor: pointer;
    line-height: 1;
    padding: 0.5rem;
    transition: opacity 0.2s ease;
  }

  .close-btn:hover {
    opacity: 0.7;
  }

  .mobile-nav {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
  }

  .mobile-nav-link {
    color: var(--text-muted, #ccc);
    font-size: 1.5rem;
    font-weight: 400;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .mobile-nav-link:hover {
    color: var(--text-primary, #fff);
  }

  /* Tablet and below - hide desktop nav, show hamburger */
  @media (max-width: 768px) {
    .nav-desktop {
      display: none;
    }

    .hamburger-btn {
      display: flex;
    }
  }

  @media (max-width: 600px) {
    .mobile-nav-link {
      font-size: 1.3rem;
    }

    .close-btn {
      top: 1rem;
      right: 1rem;
    }
  }
</style>
