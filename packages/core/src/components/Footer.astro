---
interface Props {
  footerText?: string;
}

const { footerText = 'Jawi' } = Astro.props;
---

<footer class="main-footer">
  <p>{footerText} &copy; {new Date().getFullYear()}</p>
</footer>

<style>
  .main-footer {
    margin-top: 2rem;
    padding: 1.5rem 1rem;
    text-align: center;
    color: #666;
    font-size: 0.875rem;
  }

  @media (max-width: 768px) {
    .main-footer {
      padding: 1rem 0.75rem;
    }
  }

  @media (max-width: 480px) {
    .main-footer {
      font-size: 0.75rem;
      padding: 0.75rem 0.5rem;
    }
  }
</style>
