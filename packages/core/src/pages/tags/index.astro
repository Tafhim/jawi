---
import Layout from '@jawi/core/layouts/MainLayout';
import { getAllTagsWithCounts } from '@jawi/core/utils/getAllTagsWithCounts';
import { loadConfig } from '@jawi/core/config';

const config = await loadConfig(Astro.root);
const { tags, counts } = await getAllTagsWithCounts(config.content.dir);
---

<Layout siteTitle={config.site.title} footerText={config.site.footer} dateFormat={config.display.dateFormat}>
  <div class="tags-page">
    <h1>All Tags</h1>
    <p class="subtitle">Discover posts by topic</p>

    <div class="tag-cloud">
      {tags.map(tag => (
        <a class="tag-link" href={`/tags/${tag}`}>
          <span class="tag-name">#{tag}</span>
          <span class="tag-count">{counts[tag] || 0}</span>
        </a>
      ))}
    </div>

    {tags.length === 0 && (
      <p class="no-tags">No tags yet.</p>
    )}

    <a href="/" class="back-link">&larr; Back to all posts</a>
  </div>
</Layout>

<style>
  .tags-page {
    width: 100%;
  }

  .tags-page h1 {
    font-size: 1.875rem;
    font-weight: 700;
    color: var(--text-primary, #ffffff);
    margin: 0 0 0.25rem 0;
  }

  .subtitle {
    color: #888;
    font-size: 1rem;
    margin: 0 0 1.5rem 0;
  }

  .tag-cloud {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 2rem;
  }

  .tag-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    background: #1a1a1a;
    border: 1px solid #333;
    border-radius: 6px;
    text-decoration: none;
    color: var(--text-primary);
    font-size: 0.9rem;
    transition: background 0.2s, border-color 0.2s, color 0.2s;
  }

  .tag-link:hover {
    background: #333;
    border-color: #555;
    color: #fff;
  }

  .tag-count {
    color: #888;
    font-size: 0.8rem;
    padding: 0.15rem 0.4rem;
    background: #2a2a2a;
    border-radius: 10px;
    min-width: 1.5rem;
    text-align: center;
  }

  .tag-link:hover .tag-count {
    background: #555;
    color: #fff;
  }

  .no-tags {
    color: #888;
    font-size: 1rem;
    margin-bottom: 2rem;
  }

  .back-link {
    color: #888;
    font-size: 0.9rem;
    text-decoration: none;
  }

  .back-link:hover {
    color: #fff;
  }

  @media (max-width: 600px) {
    .tags-page h1 {
      font-size: 1.5rem;
    }

    .tag-link {
      padding: 0.4rem 0.8rem;
      font-size: 0.85rem;
    }
  }
</style>
